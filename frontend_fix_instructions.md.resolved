## CORRECCIÓN 1 — `updateProfile` llama endpoint inexistente
**Archivo:** `src/services/api/auth.ts` — línea 54

### Problema
```typescript
// ROTO: /auth/profile no existe en el backend
export const updateProfile = async (data: any) => {
  return await request("/auth/profile", {
    method: "PUT",
    body: JSON.stringify(data),
  });
};
```

El backend NO tiene un endpoint `PUT /auth/profile`. El perfil del usuario está en la tabla `persons` y se actualiza vía `PUT /analitika/persons/{id_person}`.

### Corrección
```typescript
// CORRECTO: actualizar persona por id_person del usuario actual
export const updateProfile = async (idPerson: number, data: {
  name?: string;
  lastname?: string;
  email?: string;
  phone?: string;
}) => {
  return await request(`/analitika/persons/${idPerson}`, {
    method: "PUT",
    body: JSON.stringify(data),
  });
};
```

> [!IMPORTANT]
> El endpoint requiere token JWT (Bearer). El `request()` ya lo añade automáticamente.  
> El payload debe usar los campos del schema `Person`: `name`, `lastname`, `email`, `phone` — **NO** `first_name`/`last_name`.

---

## CORRECCIÓN 2 — Campañas no cargan sin empresa
**Archivo:** `src/hooks/useCampaigns.ts` — líneas 31-35

### Problema
```typescript
// ROTO: Solo carga si profile?.id_company existe
useEffect(() => {
  if (profile?.id_company) {   // ← bloquea si es null
    fetchAll();
  }
}, [profile?.id_company, fetchAll]);
```

Un usuario recién registrado **no tiene empresa todavía** (`id_company = null`). El hook nunca dispara `fetchAll()` y la pantalla de campañas siempre muestra vacío.

El backend en `GET /analitika/campaigns` ya filtra correctamente por `user_company` — no necesita `id_company` como query param.

### Corrección
```typescript
// src/hooks/useCampaigns.ts — COMPLETO CORREGIDO

import { useCallback, useEffect, useState } from 'react';
import { campaignsApi } from '../services/api/campaign';
import { Campaign } from '../services/api/types';
import { useProfile } from './useProfile';

export function useCampaigns() {
    const [campaigns, setCampaigns] = useState<Campaign[]>([]);
    const [loading, setLoading] = useState(false);
    const [error, setError] = useState<string | null>(null);
    const { profile } = useProfile();

    const fetchAll = useCallback(async () => {
        try {
            setLoading(true);
            setError(null);
            // CORRECCIÓN: no pasar id_company — el backend filtra por usuario autenticado
            const response: any = await campaignsApi.getAll();
            const data = Array.isArray(response) ? response : response?.response || [];
            setCampaigns(data);
        } catch (err: any) {
            console.error('Error fetching campaigns:', err);
            setError(err.message || 'Error al cargar campañas');
            setCampaigns([]);
        } finally {
            setLoading(false);
        }
    }, []);

    useEffect(() => {
        // CORRECCIÓN: cargar siempre que haya un perfil autenticado, con o sin empresa
        if (profile) {
            fetchAll();
        }
    }, [profile?.id_user, fetchAll]);

    return { campaigns, loading, error, reload: fetchAll };
}
```

