## CORRECCIÓN 5 — `updateProfile` no refleja cambios localmente
**Archivo:** `src/hooks/useProfile.ts` — líneas 41-58

### Problema
```typescript
const updateProfile = async (data: any) => {
  const response: any = await authService.updateProfile({
    first_name: data.first_name,  // ← campo incorrecto (debe ser 'name')
    last_name: data.last_name,    // ← campo incorrecto (debe ser 'lastname')
    phone: data.phone,
  });
  const updated = response?.response || response;
  setProfile(updated);  // ← el backend devuelve {ok:true}, no el perfil actualizado
  return updated;
};
```

Hay dos sub-bugs: los nombres de campo y que se intenta setear `{ok: true}` como perfil.

### Corrección
```typescript
const updateProfile = async (data: any) => {
  try {
    setSaving(true);
    if (!profile?.id_person) throw new Error("No hay sesión activa");

    // CORRECCIÓN: campos correctos para el schema Person del backend
    await authService.updateProfile(profile.id_person, {
      name:     data.first_name || data.name,
      lastname: data.last_name  || data.lastname,
      email:    data.email || profile.email,
      phone:    data.phone,
    });

    // CORRECCIÓN: refrescar el perfil local desde AsyncStorage/API
    await fetchProfile();
    return profile;
  } catch (err: any) {
    console.error('Error updating profile:', err);
    throw err;
  } finally {
    setSaving(false);
  }
};
```

